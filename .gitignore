# Rust
# NOTE: Cargo.lock IS committed for Tauri apps (they are binary applications,
# not libraries) to ensure reproducible builds. Only Rust *libraries* ignore it.
src-tauri/**/*.rs.bk
src-tauri/target/**/deps
src-tauri/target/**/build
src-tauri/target/**/*.d
src-tauri/target/**/*.rlib
src-tauri/target/**/*.rmeta
src-tauri/target/**/*.pdb
src-tauri/target/**/*.exe

# Cache
.cache/
coverage/
.eslintcache
*.tsbuildinfo

# Misc
*.local
