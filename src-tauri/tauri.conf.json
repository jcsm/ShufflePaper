{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "shuffle-paper",
  "version": "0.1.0",
  "identifier": "com.shuffle-paper.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ShufflePaper",
        "width": 480,
        "height": 800,
        "resizable": false,
        "maximizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["en-US"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
